<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
  <PropertyGroup>
    <!-- Self-contained is REQUIRED: the installer's promise is that a clean
         Windows machine with no .NET runtime can run the API. A framework-
         dependent publish here silently breaks the one-click install on any
         machine that never had .NET 8 installed. -->
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <PublishProvider>FileSystem</PublishProvider>
    <!-- Relative to this profile's project (backend/), so it works from any
         clone location, not one developer's machine. Visual Studio reads
         PublishUrl; `dotnet publish` reads PublishDir - keep them identical. -->
    <PublishUrl>..\installer\WebAppInstaller\Assets\Api</PublishUrl>
    <PublishDir>..\installer\WebAppInstaller\Assets\Api</PublishDir>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <_TargetId>Folder</_TargetId>
  </PropertyGroup>

  <!-- The installer bundle must connect to localhost\SQLEXPRESS (the instance
       the installer silently creates), while backend/appsettings.json keeps
       plain localhost for development. Swapping the file here removes the old
       manual "restore Assets\Api\appsettings.json after publish" step. -->
  <Target Name="UseInstallerAppSettings" AfterTargets="Publish">
    <Copy SourceFiles="$(MSBuildProjectDirectory)\appsettings.Installer.json"
          DestinationFiles="$(PublishDir)appsettings.json" />
    <Delete Files="$(PublishDir)appsettings.Installer.json;$(PublishDir)dotnet-tools.json" />
  </Target>
</Project>
